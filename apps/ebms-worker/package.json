{
	"name": "ebms-worker",
	"version": "0.1.0",
	"private": true,
	"type": "module",
	"scripts": {
		"dev": "wrangler dev",
		"login": "wrangler login",
		"build": "tsc",
		"build:validate": "tsc && wrangler deploy --dry-run --outdir dist",
		"deploy": "wrangler deploy",
		"graphql:generate": "graphql-codegen --config codegen.yml",
		"db:generate": "drizzle-kit generate",
		"db:migrate": "wrangler d1 execute ebms-db --remote --file=./drizzle/migrations/0000_init.sql",
		"db:migrate:config": "wrangler d1 execute ebms-db --remote --file=./drizzle/migrations/0001_eligibility_config.sql",
		"db:migrate:reject-reason": "node ./scripts/conditional-column-migration.mjs ebms-db --remote benefit_requests reject_reason ./drizzle/migrations/0002_reject_reason.sql",
		"db:migrate:benefit-description": "node ./scripts/conditional-column-migration.mjs ebms-db --remote benefits description ./drizzle/migrations/0003_benefit_description.sql",
		"db:migrate:employee-contract-r2-key": "node ./scripts/conditional-column-migration.mjs ebms-db --remote benefit_requests employee_contract_r2_key ./drizzle/migrations/0004_employee_contract_r2_key.sql",
		"db:migrate:employee-contract-uploaded-at": "node ./scripts/conditional-column-migration.mjs ebms-db --remote benefit_requests employee_contract_uploaded_at ./drizzle/migrations/0005_employee_contract_uploaded_at.sql",
		"db:migrate:remote": "npm run db:migrate && npm run db:migrate:config && npm run db:migrate:reject-reason && npm run db:migrate:benefit-description && npm run db:migrate:employee-contract-r2-key && npm run db:migrate:employee-contract-uploaded-at",
		"db:local": "wrangler d1 execute ebms-db --local --file=./drizzle/migrations/0000_init.sql",
		"db:local:config": "wrangler d1 execute ebms-db --local --file=./drizzle/migrations/0001_eligibility_config.sql",
		"db:local:reject-reason": "node ./scripts/conditional-column-migration.mjs ebms-db --local benefit_requests reject_reason ./drizzle/migrations/0002_reject_reason.sql",
		"db:local:benefit-description": "node ./scripts/conditional-column-migration.mjs ebms-db --local benefits description ./drizzle/migrations/0003_benefit_description.sql",
		"db:local:employee-contract-r2-key": "node ./scripts/conditional-column-migration.mjs ebms-db --local benefit_requests employee_contract_r2_key ./drizzle/migrations/0004_employee_contract_r2_key.sql",
		"db:local:employee-contract-uploaded-at": "node ./scripts/conditional-column-migration.mjs ebms-db --local benefit_requests employee_contract_uploaded_at ./drizzle/migrations/0005_employee_contract_uploaded_at.sql",
		"db:local:all": "npm run db:local && npm run db:local:config && npm run db:local:reject-reason && npm run db:local:benefit-description && npm run db:local:employee-contract-r2-key && npm run db:local:employee-contract-uploaded-at"
	},
	"dependencies": {
		"drizzle-orm": "^0.45.1",
		"graphql": "^16.13.1",
		"graphql-yoga": "^5.10.0",
		"handlebars": "^4.7.8",
		"hono": "^4.6.0",
		"pdf-lib": "^1.17.1"
	},
	"devDependencies": {
		"@cloudflare/workers-types": "^4.20241127.0",
		"@graphql-codegen/cli": "^6.1.3",
		"@graphql-codegen/typescript": "^5.0.9",
		"@graphql-codegen/typescript-resolvers": "^5.1.7",
		"drizzle-kit": "^0.28.0",
		"sentence-case": "^3.0.4",
		"typescript": "^5.6.0",
		"wrangler": "^3.94.0"
	}
}
